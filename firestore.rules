rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      let data = getUserData();
      return isAuthenticated() && (data.role == role || (data.roles != null && role in data.roles));
    }
    
    function isAdmin() {
      return hasRole('admin');
    }

    function isManager() {
      return hasRole('manager') || isAdmin();
    }

    // Global Admin override - Give Admins full access to EVERYTHING
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if (isAuthenticated() && request.auth.uid == userId);
    }

    // Patients collection
    match /patients/{patientId} {
      // Participants can read only their own record. Staff can read all.
      allow read: if isAuthenticated() && (
        (getUserData().patientId == patientId) || 
        isManager() || hasRole('social_worker') || hasRole('instructor')
      );
      allow write: if isManager() || hasRole('professional_manager');
    }
    
    // Attendance collection
    match /attendance/{docId} {
      // Participants can read only their own attendance.
      allow read: if isAuthenticated() && (
        (resource.data.patientId == getUserData().patientId) || 
        isManager() || hasRole('social_worker') || hasRole('instructor')
      );
      allow write: if isAuthenticated();
    }

    // Document Requests
    match /document_requests/{docId} {
      allow read: if isAuthenticated() && (
        (resource.data.patientId == getUserData().patientId) || 
        isManager() || hasRole('social_worker')
      );
      allow write: if isAuthenticated();
    }

    // Documents (Issued)
    match /documents/{docId} {
      allow read: if isAuthenticated() && (
        (resource.data.patientId == getUserData().patientId) || 
        isManager() || hasRole('social_worker')
      );
      allow write: if isManager() || hasRole('social_worker');
    }

    // Staff Attendance
    match /staff_attendance/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }

    // Absence Requests (Multiple names used in app)
    match /absence_requests/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }
    match /absences/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }

    // Schedule Conflicts
    match /schedule_conflicts/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }

    // Notifications
    match /notifications/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || isAuthenticated();
    }

    // Messages
    match /messages/{docId} {
      allow read, write: if isAuthenticated() && (request.auth.uid in resource.data.participants || request.auth.uid in request.resource.data.participants);
    }

    // Shopping Requests
    match /shopping_requests/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Product Pool
    match /product_pool/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || hasRole('logistics');
    }

    // Settings
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Schedules
    match /schedules/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Programs
    match /programs/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Groups
    match /groups/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Locations
    match /locations/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Global deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
