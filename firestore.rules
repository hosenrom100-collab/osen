rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Helper Functions ────────────────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Safely fetch user data. Returns null if not logged in or doc missing.
    function getUserData() {
      return (request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }
    
    function hasRole(role) {
      return request.auth != null && getUserData() != null && (
        getUserData().role == role || 
        (getUserData().roles != null && role in getUserData().roles)
      );
    }
    
    function isAdmin() {
      return hasRole('admin');
    }

    function isManager() {
      return hasRole('manager') || isAdmin();
    }

    // ─── Global Rules ────────────────────────────────────────────────────────

    // Global Admin override - Give Admins full access to MOST things
    // PRIVATE MESSAGES and their alerts are excluded from this override to protect participant privacy.
    match /{document=**} {
      allow read, write: if isAdmin() && !(request.path[3] in ['messages', 'notifications']);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Patients collection
    match /patients/{patientId} {
      // Participants can read only their own record. Staff can read all.
      allow read: if isAuthenticated() && (
        isManager() || 
        hasRole('social_worker') || 
        hasRole('instructor') ||
        (getUserData() != null && getUserData().patientId == patientId)
      );
      allow write: if isManager() || hasRole('professional_manager');
    }
    
    // Attendance collection
    match /attendance/{docId} {
      // Participants can read only their own attendance.
      allow read: if isAuthenticated() && (
        isManager() || 
        hasRole('social_worker') || 
        hasRole('instructor') ||
        (resource != null && resource.data.patientId == (getUserData() != null ? getUserData().patientId : ''))
      );
      allow write: if isAuthenticated();
    }

    // Document Requests
    match /document_requests/{docId} {
      allow read: if isAuthenticated() && (
        isManager() || 
        hasRole('social_worker') ||
        (resource != null && resource.data.patientId == (getUserData() != null ? getUserData().patientId : ''))
      );
      allow write: if isAuthenticated();
    }

    // Documents (Issued)
    match /documents/{docId} {
      allow read: if isAuthenticated() && (
        isManager() || 
        hasRole('social_worker') ||
        (resource != null && resource.data.patientId == (getUserData() != null ? getUserData().patientId : ''))
      );
      allow write: if isManager() || hasRole('social_worker');
    }

    // Staff Attendance
    match /staff_attendance/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }

    // Absence Requests (Multiple names used in app)
    match /absence_requests/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }
    match /absences/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }

    // Schedule Conflicts
    match /schedule_conflicts/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }

    // Notifications
    match /notifications/{docId} {
      // Users can read notifications sent to them.
      // Managers can see system notifications (type == 'system') in logs.
      allow read: if isAuthenticated() && (
        (request.auth.uid in resource.data.recipientIds) ||
        (isManager() && (resource.data.type == 'system'))
      );
      allow write: if isAuthenticated();
    }

    match /messages/{docId} {
      // Accessible to participants, but also to Admins and Managers for supervision.
      // They are hidden from the global log via UI filters.
      allow read, write: if isAuthenticated() && (
        isAdmin() || isManager() ||
        (resource != null && request.auth.uid in resource.data.participants) || 
        (request.resource != null && request.auth.uid in request.resource.data.participants)
      );
    }

    // Shopping Requests
    match /shopping_requests/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Product Pool
    match /product_pool/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || hasRole('logistics');
    }

    // Settings & Core Metadata
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }
    match /schedules/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }
    match /programs/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }
    match /groups/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }
    match /locations/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Announcements (News)
    match /announcements/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Global deny for everything else (fallback)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

